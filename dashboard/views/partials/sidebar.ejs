<aside class="w-64 bg-[#23272a] flex-shrink-0 flex flex-col min-h-screen p-4">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-[#5865f2]">⚔️ Vigil</h1>
    <p class="text-gray-400 text-sm">Dashboard</p>
  </div>
  <% if (typeof guild !== 'undefined' && guild) { %>
  <nav class="flex flex-col gap-2 flex-1">
    <a href="/dashboard/<%= guild.id %>" class="sidebar-link">📊 Overview</a>
    <a href="/dashboard/<%= guild.id %>/automod" class="sidebar-link">🛡️ Automod</a>
    <a href="/dashboard/<%= guild.id %>/moderation" class="sidebar-link">🔨 Moderation</a>
    <a href="/dashboard/<%= guild.id %>/logging" class="sidebar-link">📋 Logging</a>
    <a href="/dashboard/<%= guild.id %>/messages" class="sidebar-link">💬 Messages</a>
    <a href="/dashboard/<%= guild.id %>/roles" class="sidebar-link">🎭 Roles</a>
    <div class="mt-4 border-t border-gray-700 pt-4">
      <a href="/dashboard" class="sidebar-link">← All Servers</a>
    </div>
  </nav>
  <% } else { %>
  <nav class="flex flex-col gap-2 flex-1">
    <a href="/dashboard" class="sidebar-link">🏠 Home</a>
  </nav>
  <% } %>
  <div class="mt-auto pt-4 border-t border-gray-700">
    <% if (typeof user !== 'undefined' && user) { %>
    <div class="flex items-center gap-2 mb-2">
      <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-8 h-8 rounded-full" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
      <span class="text-sm text-gray-300"><%= user.username %></span>
    </div>
    <% } %>
    <a href="/auth/logout" class="sidebar-link text-red-400">🚪 Logout</a>
  </div>
</aside>

<button class="sidebar-toggle" id="sidebar-toggle">&#9776;</button>
<div class="sidebar-overlay" id="sidebar-overlay"></div>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-logo">
      <div class="sidebar-logo-icon">⚔️</div>
      <span class="sidebar-logo-name">Vigil</span>
    </div>
    <% if (typeof guild !== 'undefined' && guild) { %>
    <div class="sidebar-server-name"><%= guild.name %></div>
    <% } %>
  </div>
  <nav class="sidebar-nav">
    <% if (typeof guild !== 'undefined' && guild) { %>
    <span class="sidebar-section-label">Server</span>
    <a href="/dashboard/<%= guild.id %>" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'overview' ? 'active' : '' %>">
      <span class="nav-icon">📊</span> Overview
    </a>
    <a href="/dashboard/<%= guild.id %>/automod" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'automod' ? 'active' : '' %>">
      <span class="nav-icon">🛡️</span> Automod
    </a>
    <a href="/dashboard/<%= guild.id %>/moderation" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'moderation' ? 'active' : '' %>">
      <span class="nav-icon">🔨</span> Moderation
    </a>
    <a href="/dashboard/<%= guild.id %>/logging" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'logging' ? 'active' : '' %>">
      <span class="nav-icon">📋</span> Logging
    </a>
    <a href="/dashboard/<%= guild.id %>/messages" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'messages' ? 'active' : '' %>">
      <span class="nav-icon">💬</span> Messages
    </a>
    <a href="/dashboard/<%= guild.id %>/roles" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'roles' ? 'active' : '' %>">
      <span class="nav-icon">🎭</span> Roles
    </a>
    <a href="/dashboard/<%= guild.id %>/appeals" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'appeals' ? 'active' : '' %>">
      <span class="nav-icon">⚖️</span> Appeals
    </a>
    <hr class="sidebar-divider">
    <a href="/dashboard" class="sidebar-link">
      <span class="nav-icon">←</span> All Servers
    </a>
    <% } else { %>
    <a href="/dashboard" class="sidebar-link active">
      <span class="nav-icon">🏠</span> Home
    </a>
    <% } %>
  </nav>
  <div class="sidebar-user">
    <% if (typeof user !== 'undefined' && user) { %>
    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="sidebar-user-avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
    <span class="sidebar-user-name"><%= user.username %></span>
    <a href="/auth/logout" class="sidebar-logout" title="Logout">↗</a>
    <% } %>
  </div>
</aside>

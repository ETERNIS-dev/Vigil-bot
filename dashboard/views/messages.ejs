<%- include('partials/header') %>
<%- include('partials/sidebar') %>
<main class="flex-1 p-8 overflow-y-auto">
  <h2 class="text-3xl font-bold mb-2">💬 Messages</h2>
  <p class="text-gray-400 mb-6">Manage welcome, leave, boost, and role messages for <strong><%= guild.name %></strong></p>
  <div class="flex gap-2 mb-8">
    <% [['join','Join'],['leave','Leave'],['boost','Boost'],['rolemsg','Role']].forEach(([key,label]) => { %>
    <a href="?tab=<%= key %>" class="px-4 py-2 rounded-lg font-semibold transition-colors <%= activeTab === key ? 'bg-[#5865f2] text-white' : 'bg-[#23272a] text-gray-300 hover:bg-[#2f3136]' %>"><%= label %> Messages</a>
    <% }) %>
  </div>
  <% const currentMsgs = activeTab === 'join' ? join : activeTab === 'leave' ? leave : activeTab === 'boost' ? boost : rolemsg; %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
    <% currentMsgs.forEach(msg => { %>
    <div class="bg-[#23272a] rounded-xl p-5">
      <div class="flex items-center justify-between mb-2">
        <h3 class="font-bold"><%= msg.name %></h3>
        <span class="text-xs px-2 py-1 rounded <%= msg.enabled ? 'bg-green-900 text-green-300' : 'bg-gray-700 text-gray-400' %>"><%= msg.enabled ? 'Enabled' : 'Disabled' %></span>
      </div>
      <p class="text-gray-400 text-sm mb-1">Channel: <#<%= msg.channelId %>></p>
      <% if (msg.embed.useEmbed) { %>
      <p class="text-gray-400 text-sm mb-3">Type: Embed</p>
      <% } else { %>
      <p class="text-gray-400 text-sm mb-3 truncate">Message: <%= (msg.plainMessage || '').slice(0,60) %></p>
      <% } %>
      <div class="flex gap-2">
        <button class="delete-msg-btn flex-1 bg-red-900 hover:bg-red-800 text-red-200 py-1 rounded text-sm font-semibold" data-id="<%= msg._id %>" data-guild="<%= guild.id %>">Delete</button>
      </div>
    </div>
    <% }) %>
    <div class="bg-[#2f3136] border-2 border-dashed border-gray-600 rounded-xl p-5 flex items-center justify-center">
      <button onclick="openCreateModal('<%= activeTab %>')" class="text-gray-400 hover:text-white font-semibold">+ Add New</button>
    </div>
  </div>

  <div id="create-modal" class="hidden fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50 p-4">
    <div class="bg-[#23272a] rounded-xl p-6 w-full max-w-lg max-h-[90vh] overflow-y-auto">
      <h3 class="text-xl font-bold mb-4">Create Message</h3>
      <input type="hidden" id="modal-type" value="">
      <div class="flex flex-col gap-3">
        <div><label class="label">Name</label><input id="msg-name" type="text" class="input w-full" placeholder="e.g. Main Welcome"></div>
        <div><label class="label">Channel</label><select id="msg-channel" class="input w-full"><% channels.forEach(c => { %><option value="<%= c.id %>">#<%= c.name %></option><% }) %></select></div>
        <div class="flex items-center gap-2"><input id="msg-use-embed" type="checkbox" checked class="w-4 h-4"> <label class="text-sm">Use Embed</label></div>
        <div id="embed-fields">
          <div><label class="label">Embed Color</label><input id="msg-color" type="color" value="#5865f2" class="h-10 w-full rounded cursor-pointer"></div>
          <div><label class="label">Title</label><input id="msg-title" type="text" class="input w-full" placeholder="Welcome to {server}!"></div>
          <div><label class="label">Description</label><textarea id="msg-desc" class="input w-full h-24" placeholder="Hey {user}, welcome to {server}! You are member #{memberCount}."></textarea></div>
          <div><label class="label">Footer</label><input id="msg-footer" type="text" class="input w-full"></div>
        </div>
        <div id="plain-field" class="hidden"><label class="label">Plain Message</label><textarea id="msg-plain" class="input w-full h-24"></textarea></div>
        <div class="flex items-center gap-2"><input id="msg-ping" type="checkbox" class="w-4 h-4"> <label class="text-sm">Ping User</label></div>
        <p class="text-gray-500 text-xs">Variables: {user} {username} {server} {memberCount} {boostCount} {roleAdded}</p>
      </div>
      <div class="flex gap-3 mt-4">
        <button onclick="saveMessage('<%= guild.id %>')" class="flex-1 bg-[#5865f2] hover:bg-[#4752c4] text-white py-2 rounded-lg font-semibold">Save</button>
        <button onclick="document.getElementById('create-modal').classList.add('hidden')" class="flex-1 bg-[#2f3136] text-gray-300 py-2 rounded-lg font-semibold">Cancel</button>
      </div>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
<script>
function openCreateModal(type) {
  document.getElementById('modal-type').value = type;
  document.getElementById('create-modal').classList.remove('hidden');
}
document.getElementById('msg-use-embed').addEventListener('change', function() {
  document.getElementById('embed-fields').classList.toggle('hidden', !this.checked);
  document.getElementById('plain-field').classList.toggle('hidden', this.checked);
});
async function saveMessage(guildId) {
  const data = {
    type: document.getElementById('modal-type').value,
    name: document.getElementById('msg-name').value,
    channelId: document.getElementById('msg-channel').value,
    useEmbed: document.getElementById('msg-use-embed').checked,
    color: document.getElementById('msg-color').value,
    title: document.getElementById('msg-title').value,
    description: document.getElementById('msg-desc').value,
    footer: document.getElementById('msg-footer').value,
    pingUser: document.getElementById('msg-ping').checked,
    plainMessage: document.getElementById('msg-plain').value,
  };
  const res = await fetch(`/dashboard/${guildId}/messages`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  const json = await res.json();
  if (json.success) { showToast('Message saved!', true); setTimeout(() => location.reload(), 1000); }
  else showToast(json.error || 'Error saving', false);
}
document.querySelectorAll('.delete-msg-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('Delete this message?')) return;
    const res = await fetch(`/dashboard/${btn.dataset.guild}/messages/${btn.dataset.id}`, { method: 'DELETE' });
    const json = await res.json();
    if (json.success) { showToast('Deleted!', true); setTimeout(() => location.reload(), 800); }
    else showToast('Error deleting', false);
  });
});
</script>

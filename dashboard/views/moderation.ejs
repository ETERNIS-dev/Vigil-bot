<%- include('partials/header') %>
<%- include('partials/sidebar', { guild, user, activePage: 'moderation' }) %>
<main class="main-content">
  <div class="breadcrumb">
    <a href="/dashboard">Dashboard</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/dashboard/<%= guild.id %>"><%= guild.name %></a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">Moderation</span>
  </div>

  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <h1 class="page-title">🔨 Moderation Cases</h1>
      <p class="page-subtitle"><%= totalCases.toLocaleString() %> total cases for <strong><%= guild.name %></strong></p>
    </div>
  </div>

  <div class="card" style="padding:16px 20px;margin-bottom:20px;">
    <form method="GET" style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end;">
      <div style="flex:1;min-width:160px;">
        <label class="label">Search</label>
        <input type="text" name="search" value="<%= query.search || '' %>" placeholder="User or moderator..." class="input">
      </div>
      <div style="min-width:160px;">
        <label class="label">Type</label>
        <select name="type" class="input">
          <option value="">All Types</option>
          <% ['BAN','UNBAN','KICK','MUTE','UNMUTE','WARN','LOCK','AUTOMOD_SPAM','AUTOMOD_CAPS','AUTOMOD_WORDS','AUTOMOD_LINKS','AUTOMOD_INVITES','AUTOMOD_MENTIONS','AUTOMOD_ATTACHMENTS','AUTOMOD_EMOJIS','AUTOMOD_LINES','AUTOMOD_CHANNELSPAM'].forEach(t => { %>
          <option value="<%= t %>" <%= query.type === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div style="display:flex;gap:8px;align-items:flex-end;">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a href="/dashboard/<%= guild.id %>/moderation" class="btn btn-secondary">Reset</a>
      </div>
    </form>
  </div>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Case</th>
          <th>Type</th>
          <th>User</th>
          <th>Moderator</th>
          <th>Reason</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!cases.length) { %>
        <tr><td colspan="7" style="text-align:center;padding:32px;color:var(--text-muted);">No cases found.</td></tr>
        <% } %>
        <% cases.forEach(c => { %>
        <tr>
          <td class="mono" style="color:var(--text-secondary);">#<%= c.caseNumber %></td>
          <td><span class="case-badge <%= c.type.toLowerCase().replace('automod_','') %>"><%= c.type %></span></td>
          <td><%= c.userTag %></td>
          <td style="color:var(--text-muted);"><%= c.moderatorTag %></td>
          <td style="max-width:200px;" class="truncate text-muted"><%= c.reason %></td>
          <td class="text-muted" style="white-space:nowrap;"><%= new Date(c.createdAt).toLocaleDateString() %></td>
          <td>
            <button class="btn btn-danger btn-xs delete-case-btn" data-case="<%= c.caseNumber %>" data-guild="<%= guild.id %>">Delete</button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
  <div style="display:flex;gap:6px;margin-top:16px;justify-content:center;flex-wrap:wrap;">
    <% for (let i = 0; i < totalPages; i++) { %>
    <a href="?page=<%= i %>&search=<%= query.search || '' %>&type=<%= query.type || '' %>"
       style="padding:6px 12px;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;border:1px solid var(--card-border);background:<%= i === page ? 'var(--accent)' : 'var(--card-bg)' %>;color:<%= i === page ? 'white' : 'var(--text-secondary)' %>;">
      <%= i + 1 %>
    </a>
    <% } %>
  </div>
  <% } %>
</main>
<%- include('partials/footer') %>

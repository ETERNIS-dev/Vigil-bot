<%- include('partials/header') %>
<%- include('partials/sidebar', { guild, user, activePage: 'roles' }) %>
<main class="main-content">
  <div class="breadcrumb">
    <a href="/dashboard">Dashboard</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/dashboard/<%= guild.id %>"><%= guild.name %></a>
    <span class="breadcrumb-sep">›</span>
    <span class="breadcrumb-current">Roles</span>
  </div>

  <div class="page-header">
    <h1 class="page-title">🎭 Roles</h1>
    <p class="page-subtitle">Manage auto-roles and reaction roles for <strong><%= guild.name %></strong></p>
  </div>

  <div class="card" style="margin-bottom:20px;">
    <div class="card-header">
      <div>
        <div class="card-title">Auto Roles</div>
        <div class="card-desc">Roles automatically assigned to new members</div>
      </div>
    </div>
    <div class="card-divider"></div>
    <div style="padding:20px;">
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;min-height:36px;" id="autorole-list">
        <% (guildSettings.autoroles || []).forEach(roleId => { %>
        <% const role = roles.find(r => r.id === roleId); %>
        <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;font-size:13px;font-weight:600;background:rgba(124,58,237,0.15);color:#a78bfa;border:1px solid rgba(124,58,237,0.3);">
          <%= role ? role.name : roleId %>
          <button class="remove-autorole" data-id="<%= roleId %>" style="background:none;border:none;cursor:pointer;color:#a78bfa;font-size:15px;opacity:0.7;">×</button>
        </span>
        <% }) %>
      </div>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:16px;">
        <select id="add-autorole-select" class="input" style="flex:1;max-width:240px;">
          <option value="">Select role to add...</option>
          <% roles.forEach(r => { %><option value="<%= r.id %>"><%= r.name %></option><% }) %>
        </select>
        <button id="add-autorole-btn" class="btn btn-primary">Add</button>
      </div>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
        <label class="label" style="margin:0;">Delay (seconds):</label>
        <input id="autorole-delay" type="number" min="0" value="<%= guildSettings.autoroleDelay || 0 %>" class="input" style="width:100px;">
      </div>
      <button id="save-autoroles-btn" data-guild="<%= guild.id %>" class="btn btn-primary">Save Auto Roles</button>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">Reaction Roles</div>
        <div class="card-desc">Let members self-assign roles with reactions</div>
      </div>
      <button onclick="document.getElementById('create-rr-modal').style.display='flex'" class="btn btn-primary btn-sm">+ Create New</button>
    </div>
    <div class="card-divider"></div>
    <div style="padding:20px;display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;">
      <% if (!reactionRoles.length) { %>
      <div style="grid-column:1/-1;text-align:center;padding:32px;color:var(--text-muted);">No reaction roles yet.</div>
      <% } %>
      <% reactionRoles.forEach(rr => { %>
      <div class="card" style="padding:16px;">
        <div style="font-weight:700;font-size:14px;margin-bottom:6px;"><%= rr.embed.title || 'Untitled' %></div>
        <div class="text-muted text-xs" style="margin-bottom:4px;">Channel: <#<%= rr.channelId %>></div>
        <div class="text-muted text-xs" style="margin-bottom:12px;"><%= rr.options.length %> options</div>
        <button class="btn btn-danger btn-xs w-full delete-rr-btn" data-id="<%= rr._id %>" data-guild="<%= guild.id %>">Delete</button>
      </div>
      <% }) %>
    </div>
  </div>

  <div id="create-rr-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:9000;align-items:center;justify-content:center;backdrop-filter:blur(4px);">
    <div style="background:var(--card-bg);border:1px solid var(--card-border);border-radius:16px;padding:28px;width:100%;max-width:500px;max-height:90vh;overflow-y:auto;margin:16px;">
      <h3 style="font-size:17px;font-weight:700;margin-bottom:16px;">Create Reaction Role</h3>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div><label class="label">Channel</label><select id="rr-channel" class="input"><% channels.forEach(c => { %><option value="<%= c.id %>">#<%= c.name %></option><% }) %></select></div>
        <div><label class="label">Embed Title</label><input id="rr-title" type="text" class="input" placeholder="Choose Your Roles"></div>
        <div><label class="label">Description</label><textarea id="rr-desc-embed" class="input" rows="2"></textarea></div>
        <div><label class="label">Color</label><input id="rr-color" type="color" value="#7c3aed" class="input" style="height:42px;cursor:pointer;"></div>
        <div>
          <label class="label">Options</label>
          <div id="rr-options"></div>
          <button type="button" onclick="addRROption()" class="btn btn-secondary btn-sm" style="margin-top:8px;">+ Add Option</button>
        </div>
      </div>
      <div style="display:flex;gap:10px;margin-top:20px;">
        <button onclick="createReactionRole('<%= guild.id %>')" class="btn btn-primary" style="flex:1;">Create</button>
        <button onclick="document.getElementById('create-rr-modal').style.display='none'" class="btn btn-secondary" style="flex:1;">Cancel</button>
      </div>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
<script>
const allRoles = <%- JSON.stringify(roles) %>;
let selectedAutoroles = <%- JSON.stringify(guildSettings.autoroles || []) %>;

document.getElementById('add-autorole-btn').addEventListener('click', () => {
  const sel = document.getElementById('add-autorole-select');
  const id = sel.value;
  if (!id || selectedAutoroles.includes(id)) return;
  selectedAutoroles.push(id);
  const role = allRoles.find(r => r.id === id);
  const list = document.getElementById('autorole-list');
  const span = document.createElement('span');
  span.style.cssText = 'display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;font-size:13px;font-weight:600;background:rgba(124,58,237,0.15);color:#a78bfa;border:1px solid rgba(124,58,237,0.3);';
  span.innerHTML = `${role?.name || id} <button style="background:none;border:none;cursor:pointer;color:#a78bfa;font-size:15px;opacity:0.7;" onclick="this.closest('span').remove();selectedAutoroles=selectedAutoroles.filter(i=>i!=='${id}')">×</button>`;
  list.appendChild(span);
  sel.value = '';
});

document.querySelectorAll('.remove-autorole').forEach(btn => {
  btn.addEventListener('click', function() {
    selectedAutoroles = selectedAutoroles.filter(i => i !== this.dataset.id);
    this.closest('span').remove();
  });
});

document.getElementById('save-autoroles-btn').addEventListener('click', async function() {
  const delay = document.getElementById('autorole-delay').value;
  const res = await fetch(`/dashboard/${this.dataset.guild}/roles/autorole`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ autoroles: selectedAutoroles, delay }) });
  const json = await res.json();
  showToast(json.success ? 'Auto roles saved!' : (json.error || 'Error'), json.success);
});

document.querySelectorAll('.delete-rr-btn').forEach(btn => {
  btn.addEventListener('click', async function() {
    if (!confirm('Delete this reaction role?')) return;
    const res = await fetch(`/dashboard/${this.dataset.guild}/roles/reactionrole/${this.dataset.id}`, { method: 'DELETE' });
    const json = await res.json();
    if (json.success) { showToast('Deleted!', true); setTimeout(() => location.reload(), 700); }
  });
});

function addRROption() {
  const div = document.createElement('div');
  div.style.cssText = 'display:flex;gap:8px;margin-bottom:8px;';
  div.innerHTML = `<input type="text" placeholder="emoji" class="input rr-emoji" style="width:70px;"><select class="input rr-role" style="flex:1;"><option value="">Role...</option>${allRoles.map(r => `<option value="${r.id}">${r.name}</option>`).join('')}</select><input type="text" placeholder="label" class="input rr-rdesc" style="flex:1;">`;
  document.getElementById('rr-options').appendChild(div);
}

async function createReactionRole(guildId) {
  const options = [...document.querySelectorAll('#rr-options > div')].map(d => ({
    emoji: d.querySelector('.rr-emoji').value,
    roleId: d.querySelector('.rr-role').value,
    description: d.querySelector('.rr-rdesc').value,
  })).filter(o => o.emoji && o.roleId);
  const data = { channelId: document.getElementById('rr-channel').value, title: document.getElementById('rr-title').value, description: document.getElementById('rr-desc-embed').value, color: document.getElementById('rr-color').value, options };
  const res = await fetch(`/dashboard/${guildId}/roles/reactionrole`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  const json = await res.json();
  if (json.success) { showToast('Reaction role created!', true); setTimeout(() => location.reload(), 900); }
  else showToast(json.error || 'Error', false);
}

addRROption();
</script>

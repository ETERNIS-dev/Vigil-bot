<%- include('partials/header') %>
<%- include('partials/sidebar') %>
<main class="flex-1 p-8">
  <div class="flex items-center gap-4 mb-8">
    <img src="<%= guild.icon || 'https://cdn.discordapp.com/embed/avatars/0.png' %>" class="w-12 h-12 rounded-full">
    <div>
      <h2 class="text-3xl font-bold"><%= guild.name %></h2>
      <p class="text-gray-400">Server Overview</p>
    </div>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-[#23272a] rounded-xl p-6">
      <p class="text-gray-400 text-sm">Total Members</p>
      <p class="text-3xl font-bold text-[#5865f2]"><%= guild.memberCount %></p>
    </div>
    <div class="bg-[#23272a] rounded-xl p-6">
      <p class="text-gray-400 text-sm">Total Cases</p>
      <p class="text-3xl font-bold text-[#5865f2]"><%= totalCases %></p>
    </div>
    <div class="bg-[#23272a] rounded-xl p-6">
      <p class="text-gray-400 text-sm">Active Automod Rules</p>
      <p class="text-3xl font-bold text-[#5865f2]"><%= activeRules %></p>
    </div>
  </div>
  <div class="bg-[#23272a] rounded-xl p-6 mb-8">
    <h3 class="text-xl font-bold mb-4">Recent Cases</h3>
    <% if (!recentCases.length) { %>
    <p class="text-gray-400">No cases yet.</p>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead><tr class="text-gray-400 border-b border-gray-700"><th class="text-left pb-2">Case</th><th class="text-left pb-2">Type</th><th class="text-left pb-2">User</th><th class="text-left pb-2">Moderator</th><th class="text-left pb-2">Date</th></tr></thead>
        <tbody>
          <% recentCases.forEach(c => { %>
          <tr class="border-b border-gray-800">
            <td class="py-2">#<%= c.caseNumber %></td>
            <td class="py-2"><span class="case-badge <%= c.type.toLowerCase() %>"><%= c.type %></span></td>
            <td class="py-2"><%= c.userTag %></td>
            <td class="py-2"><%= c.moderatorTag %></td>
            <td class="py-2 text-gray-400"><%= new Date(c.createdAt).toLocaleDateString() %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
    <a href="/dashboard/<%= guild.id %>/automod" class="bg-[#5865f2] hover:bg-[#4752c4] rounded-xl p-4 text-center font-semibold transition-colors">🛡️ Automod</a>
    <a href="/dashboard/<%= guild.id %>/moderation" class="bg-[#2f3136] hover:bg-[#393c43] rounded-xl p-4 text-center font-semibold transition-colors">🔨 Cases</a>
    <a href="/dashboard/<%= guild.id %>/logging" class="bg-[#2f3136] hover:bg-[#393c43] rounded-xl p-4 text-center font-semibold transition-colors">📋 Logging</a>
    <a href="/dashboard/<%= guild.id %>/messages" class="bg-[#2f3136] hover:bg-[#393c43] rounded-xl p-4 text-center font-semibold transition-colors">💬 Messages</a>
    <a href="/dashboard/<%= guild.id %>/roles" class="bg-[#2f3136] hover:bg-[#393c43] rounded-xl p-4 text-center font-semibold transition-colors">🎭 Roles</a>
  </div>
</main>
<%- include('partials/footer') %>

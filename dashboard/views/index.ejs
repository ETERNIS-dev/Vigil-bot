<%- include('partials/header') %>
<%- include('partials/sidebar', { guild: null }) %>
<main class="flex-1 p-8">
  <h2 class="text-3xl font-bold mb-2">Your Servers</h2>
  <p class="text-gray-400 mb-8">Select a server to manage.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    <% guilds.forEach(g => { %>
    <div class="bg-[#23272a] rounded-xl p-6 flex flex-col items-center gap-4 hover:bg-[#2f3136] transition-colors">
      <img src="<%= g.icon || 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="<%= g.name %>" class="w-16 h-16 rounded-full">
      <div class="text-center">
        <h3 class="font-bold text-lg"><%= g.name %></h3>
        <p class="text-gray-400 text-sm"><%= g.memberCount %> members</p>
      </div>
      <a href="/dashboard/<%= g.id %>" class="bg-[#5865f2] hover:bg-[#4752c4] text-white px-6 py-2 rounded-lg font-semibold transition-colors w-full text-center">Manage</a>
    </div>
    <% }) %>
  </div>
</main>
<%- include('partials/footer') %>

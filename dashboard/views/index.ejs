<%- include('partials/header') %>
<%- include('partials/sidebar', { guild: null, user: user }) %>
<main class="main-content">
  <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
    <div>
      <h1 class="page-title">Your Servers</h1>
      <p class="page-subtitle">Select a server to manage with Vigil.</p>
    </div>
    <a href="https://discord.com/oauth2/authorize?client_id=<%= process.env.CLIENT_ID %>&permissions=8&scope=bot" target="_blank" rel="noopener" class="btn btn-primary">
      ➕ Invite Vigil
    </a>
  </div>

  <% if (!guilds.length) { %>
  <div class="card" style="text-align:center;padding:48px 24px;">
    <div style="font-size:48px;margin-bottom:12px;">🤔</div>
    <div style="font-size:16px;font-weight:700;margin-bottom:8px;">No servers found</div>
    <p class="text-muted text-sm" style="margin-bottom:20px;">Vigil isn't in any of your servers yet.</p>
    <a href="https://discord.com/oauth2/authorize?client_id=<%= process.env.CLIENT_ID %>&permissions=8&scope=bot" target="_blank" class="btn btn-primary">Add to Server</a>
  </div>
  <% } else { %>
  <div class="grid-auto">
    <% guilds.forEach(g => { %>
    <div class="server-card" onclick="location.href='/dashboard/<%= g.id %>'">
      <img src="<%= g.icon || 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="<%= g.name %>" class="server-avatar" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
      <div>
        <div class="server-name"><%= g.name %></div>
        <div class="server-members"><%= g.memberCount.toLocaleString() %> members</div>
      </div>
      <a href="/dashboard/<%= g.id %>" class="btn btn-primary" style="width:100%" onclick="event.stopPropagation()">Manage</a>
    </div>
    <% }) %>
  </div>
  <% } %>
</main>
<%- include('partials/footer') %>
